      "name": "Webhook",
      "webhookId": "de4c7f25-a7fb-4e87-b991-6f1f8f05b039"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=岗位JD：\n\n{{ $json.body.JD }}",
        "messages": {
          "messageValues": [
            {
              "message": "你是一位资深招聘顾问。  用户接下来会发给你一份岗位JD。  请严格分析岗位要求，并按照指定JSON格式返回结果。  规则：  1. 提取岗位最重要的5项硬技能    - 仅保留硬技能    - 按重要程度排序  2. 判断岗位等级    - 只能返回：      初级      中级      高级  3. 预测10个高频面试问题    - 覆盖基础知识    - 覆盖业务场景    - 覆盖实操案例  4. 给出简历优化建议    - 技能匹配    - 经历优化    - 关键词补充    - 避坑要点  5. 总结岗位核心职责  输出格式：  {   \"top_5_skills\": [     \"\",     \"\",     \"\",     \"\",     \"\"   ],   \"experience_level\": \"\",   \"interview_questions\": [     {       \"question\": \"\",       \"type\": \"基础/业务/实操\",       \"purpose\": \"\"     }   ],   \"resume_optimization\": {     \"skills_match\": \"\",     \"experience_improvement\": \"\",     \"keywords_to_add\": [],     \"pitfalls\": \"\"   },   \"summary\": \"\" }  要求：  - 只返回JSON - 不要Markdown - 不要代码块 - 不要解释 - 保证JSON合法可解析"
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        320,
        0
      ],
      "id": "8fccac1f-5df4-484f-a562-5d5b094f285a",
      "name": "Basic LLM Chain"
    },
    {
