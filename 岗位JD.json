        "responseBody": "={{\n{\n  success: true,\n  message: \"岗位分析已完成，并已写入 Google Sheets\",\n  experience_level: $json.experience_level,\n  top_5_skills: $json.top_5_skills,\n  summary: $json.summary\n}\n}}",
